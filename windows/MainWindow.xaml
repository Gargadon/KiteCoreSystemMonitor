<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="KiteCoreWindowsMonitor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KiteCoreWindowsMonitor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Kite Core System Monitor"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" PointerPressed="DragWindow_PointerPressed" Background="Transparent">
        <Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutSubItem x:Name="MascotMenu" Text="Mascot">
                    <ToggleMenuFlyoutItem x:Name="MascotTetsu" Text="Tetsuya &quot;Tetsu&quot; Kurobane" IsChecked="True" Click="MascotTetsu_Click"/>
                    <ToggleMenuFlyoutItem x:Name="MascotHakka" Text="Souta &quot;Hakka&quot; Aoyama" IsChecked="False" Click="MascotHakka_Click"/>
                </MenuFlyoutSubItem>
                <MenuFlyoutSubItem x:Name="ColorMenu" Text="Core Glow Color">
                    <MenuFlyoutItem x:Name="ColorCyanItem" Text="Cyan (Default)" Click="ColorCyan_Click"/>
                    <MenuFlyoutItem x:Name="ColorPurpleItem" Text="Purple" Click="ColorPurple_Click"/>
                    <MenuFlyoutItem x:Name="ColorEmeraldItem" Text="Emerald" Click="ColorEmerald_Click"/>
                    <MenuFlyoutItem x:Name="ColorAmberItem" Text="Amber" Click="ColorAmber_Click"/>
                    <MenuFlyoutItem x:Name="ColorRoseItem" Text="Rose" Click="ColorRose_Click"/>
                </MenuFlyoutSubItem>
                <ToggleMenuFlyoutItem x:Name="ToggleLabelsItem" Text="Show Extra Labels" IsChecked="True" Click="ToggleLabels_Click"/>
                <ToggleMenuFlyoutItem x:Name="PinToDesktopItem" Text="Pin to Desktop" IsChecked="False" Click="PinToDesktop_Click"/>
                <ToggleMenuFlyoutItem x:Name="StartWithWindowsItem" Text="Start with Windows" IsChecked="False" Click="StartWithWindows_Click"/>
                <MenuFlyoutSubItem x:Name="OpacityMenu" Text="Widget Opacity">
                    <ToggleMenuFlyoutItem x:Name="Opacity100" Text="100%" Click="Opacity_Click"/>
                    <ToggleMenuFlyoutItem x:Name="Opacity80" Text="80%" Click="Opacity_Click"/>
                    <ToggleMenuFlyoutItem x:Name="Opacity60" Text="60%" Click="Opacity_Click"/>
                    <ToggleMenuFlyoutItem x:Name="Opacity40" Text="40%" Click="Opacity_Click"/>
                    <ToggleMenuFlyoutItem x:Name="Opacity20" Text="20%" Click="Opacity_Click"/>
                </MenuFlyoutSubItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutSubItem x:Name="LanguageMenu" Text="Language / Idioma">
                    <ToggleMenuFlyoutItem x:Name="LangEnglish" Text="English" IsChecked="False" Click="LangEnglish_Click"/>
                    <ToggleMenuFlyoutItem x:Name="LangSpanish" Text="Español" IsChecked="True" Click="LangSpanish_Click"/>
                    <ToggleMenuFlyoutItem x:Name="LangFrench" Text="Français" IsChecked="False" Click="LangFrench_Click"/>
                    <ToggleMenuFlyoutItem x:Name="LangItalian" Text="Italiano" IsChecked="False" Click="LangItalian_Click"/>
                    <ToggleMenuFlyoutItem x:Name="LangGerman" Text="Deutsch" IsChecked="False" Click="LangGerman_Click"/>
                    <ToggleMenuFlyoutItem x:Name="LangPortuguese" Text="Português" IsChecked="False" Click="LangPortuguese_Click"/>
                    <ToggleMenuFlyoutItem x:Name="LangChinese" Text="简体中文" IsChecked="False" Click="LangChinese_Click"/>
                    <ToggleMenuFlyoutItem x:Name="LangJapanese" Text="日本語" IsChecked="False" Click="LangJapanese_Click"/>
                    <ToggleMenuFlyoutItem x:Name="LangKorean" Text="한국어" IsChecked="False" Click="LangKorean_Click"/>
                </MenuFlyoutSubItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="AboutItem" Text="About Widget" Click="About_Click" Icon="Info"/>
                <MenuFlyoutItem x:Name="ExitItem" Text="Exit Widget" Click="Exit_Click" Icon="Cancel"/>
            </MenuFlyout>
        </Grid.ContextFlyout>

        <!-- Main Card Widget -->
        <Border x:Name="MainBorder" Margin="10" CornerRadius="20" Background="#A0121212" BorderThickness="1.5" BorderBrush="#35FFFFFF">
            <Grid Padding="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Core Gauge Visual Area -->
                <Grid Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Spinning Core Rotation -->
                    <Grid x:Name="CoreRingContainer" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="CoreRingRotation" Angle="0" />
                        </Grid.RenderTransform>

                        <!-- Outer Highlight Ring -->
                        <Ellipse Margin="14" Stroke="{x:Null}" StrokeThickness="1" Opacity="0.15" x:Name="OuterHighlightRing"/>

                        <!-- CPU Arc Gauge (Left side) -->
                        <Path StrokeThickness="8" StrokeEndLineCap="Round" x:Name="CpuPath">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure x:Name="CpuPathFigure">
                                        <ArcSegment x:Name="CpuArcSegment" SweepDirection="Clockwise" />
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>

                        <!-- RAM Arc Gauge (Right side) -->
                        <Path StrokeThickness="8" StrokeEndLineCap="Round" x:Name="RamPath">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure x:Name="RamPathFigure">
                                        <ArcSegment x:Name="RamArcSegment" SweepDirection="Clockwise" />
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>
                    </Grid>

                    <!-- Center Display (Mascot and Statistics) -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                        <!-- Mascot Image -->
                        <Image x:Name="MascotSprite" Width="68" Height="68" Stretch="Uniform" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <ScaleTransform x:Name="MascotScale" ScaleX="1.0" ScaleY="1.0" />
                            </Image.RenderTransform>
                        </Image>

                        <!-- Stats Texts -->
                        <TextBlock x:Name="CpuText" Text="0% CPU" FontWeight="Bold" FontSize="12" FontFamily="Courier New" HorizontalAlignment="Center" Foreground="White" />
                        <TextBlock x:Name="RamText" Text="0% RAM" FontSize="11" FontFamily="Courier New" HorizontalAlignment="Center" Foreground="#FFA0A0A0" />
                    </StackPanel>
                </Grid>

                <!-- Extra Information Row -->
                <Grid x:Name="ExtraInfoRow" Grid.Row="1" Margin="8,0,8,4" Height="20" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusText" Text="CORE STATUS: ONLINE" FontSize="9.5" FontWeight="Bold" VerticalAlignment="Center" Foreground="#FF00F0FF" />
                    <TextBlock x:Name="SubstatusText" Grid.Column="1" Text="SYSTEM: ACTIVE" FontSize="9.5" VerticalAlignment="Center" Foreground="#FFA0A0A0" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
